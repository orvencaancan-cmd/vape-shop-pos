# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# ^ these accept either the legacy anon/service_role JWTs or the newer
# sb_publishable_.../sb_secret_... key format — both work the same way

# Stripe (test mode keys to start)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Base URL of the deployed app (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
